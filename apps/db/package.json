{
  "name": "db",
  "version": "0.0.0",
  "imports": {
    "#env": "./env.ts",
    "#schemas": "./drizzle/schema.ts"
  },
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "db:start": "sh ./migration/start.sh",
    "db:stop": "docker compose stop",
    "db:clear": "docker compose down",
    "db:restart": "docker compose restart",
    "db:pull": "npx drizzle-kit pull",
    "db:migration": "cat ./migration/init.sh | sh"
  },
  "type": "module",
  "dependencies": {
    "@repo/validator": "*",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.22.3",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@repo/ts-config": "*",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10"
  }
}
