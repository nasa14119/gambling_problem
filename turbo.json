{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "db:migration": {
      "cache": false
    },
    "db:start": {
      "cache": false,
      "persistent": false
    },
    "db:stop": {
      "cache": false
    },
    "db:restart": {
      "cache": false
    },
    "db:clear": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^db#db:start"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^client#build"],
      "cache": false
    }
  }
}
